# Supabase (required for contact form + admin login)
# Copy this file to `.env` and fill in values from Supabase → Project Settings → API
# In `npm run dev`, VITE_SUPABASE_URL is used to proxy Edge Functions via same-origin /__sb_functions (avoids CORS).
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: override Edge Functions base URL (defaults to VITE_SUPABASE_URL/functions/v1)
# VITE_SUPABASE_FUNCTIONS_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1
